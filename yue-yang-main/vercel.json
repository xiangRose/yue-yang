{
  "version": 2,
  "builds":[
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites":[
    { "source": "/blog.html", "destination": "/html/blog.html" },
    { "source": "/blog-post.html", "destination": "/html/blog-post.html" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/images/(.*)", "destination": "/images/$1" }
  ]
}