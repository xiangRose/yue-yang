{
  "version": 2,
  "builds":[
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "html/**/*", "use": "@vercel/static" },
    { "src": "css/**/*", "use": "@vercel/static" },
    { "src": "js/**/*", "use": "@vercel/static" },
    { "src": "images/**/*", "use": "@vercel/static" }
  ],
  "rewrites":[
    { "source": "/", "destination": "/html/index.html" },
    { "source": "/:name.html", "destination": "/html/:name.html" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/images/(.*)", "destination": "/images/$1" },
    { "source": "/api/blog-posts", "destination": "/api/blog-posts.js" },
    { "source": "/api/(.*)", "destination": "/server.js" }
  ]
}