{
  "version": 2,
  "builds":[
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites":[
    { "source": "/", "destination": "/html/index.html" },
    { "source": "/:name.html", "destination": "/html/:name.html" },
    { "source": "/css/:path*", "destination": "/css/:path*" },
    { "source": "/js/:path*", "destination": "/js/:path*" },
    { "source": "/images/:path*", "destination": "/images/:path*" },
    { "source": "/api/blog-posts", "destination": "/api/blog-posts.js" },
    { "source": "/api/:path*", "destination": "/server.js" }
  ]
}